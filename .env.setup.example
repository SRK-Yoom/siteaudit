# Copy to .env.setup and fill in. Used by scripts/setup-supabase-auth.mjs (one-time auth setup).

# From https://supabase.com/dashboard/account/tokens (Personal Access Token)
SUPABASE_ACCESS_TOKEN=

# From your project URL: https://THIS-PART.supabase.co
SUPABASE_PROJECT_REF=

# Your live site URL (no trailing slash), e.g. https://siteaudit-rho.vercel.app
SITE_URL=https://siteaudit-rho.vercel.app

# From Google Cloud Console → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# Application type: Web application
# Authorized redirect URIs: add https://YOUR-SITE/auth/callback (run script once to confirm URL)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: Apple Sign In (Supabase dashboard is easier for Apple; leave blank to skip)
# APPLE_CLIENT_ID=
# APPLE_SECRET=
