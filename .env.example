# ── Site URL ────────────────────────────────────────────────────────────────
# Used to generate magic-link URLs in emails.
# Local: http://localhost:3000
# Production: https://siteaudit-rho.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000


# ── Google PageSpeed Insights API Key ──────────────────────────────────────
# Without a key: works fine, ~25 requests per 100 seconds
# With a free key: 25,000 requests/day
# Get one at: https://console.cloud.google.com/ → PageSpeed Insights API
PAGESPEED_API_KEY=


# ── Supabase ────────────────────────────────────────────────────────────────
# 1. Go to https://supabase.com → open your project
# 2. Settings → API → copy Project URL and anon public key
# 3. Run ALL three SQL files in Supabase SQL Editor (in order):
#    - supabase/schema.sql
#    - supabase/add_leads_table.sql
#    - supabase/add_report_tokens_table.sql
# 4. (Optional) One-time auth setup for Google/Apple login and redirect URLs:
#    See docs/SETUP-AUTH.md. Run: node scripts/setup-supabase-auth.mjs (after filling .env.setup).
#    Or in Dashboard: Authentication → URL Configuration → add redirect URL:
#    https://siteaudit-rho.vercel.app/auth/callback
#
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here


# ── Resend (email delivery) ──────────────────────────────────────────────────
# Required for sending magic-link report emails to users.
# 1. Create a free account at https://resend.com
# 2. API Keys → Create API Key → copy it here
# 3. Domains → Add your sending domain (or use onboarding@resend.dev for testing)
# 4. If using a custom domain, set RESEND_FROM_EMAIL accordingly.
#
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=SiteScore <onboarding@resend.dev>


# ── Stripe ──────────────────────────────────────────────────────────────────
# Get your keys at: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY: starts with sk_test_ (test) or sk_live_ (production)
# STRIPE_PUBLISHABLE_KEY: starts with pk_test_ or pk_live_
# STRIPE_WEBHOOK_SECRET: get this after running: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
